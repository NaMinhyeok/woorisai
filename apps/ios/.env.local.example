# Local signed-device Firebase verification inputs.
# Copy this file to .env.local, keep that file mode 0600, and replace every placeholder.
WOORISAI_FIREBASE_DEBUG_CONFIG_PATH=<absolute-path-to-debug-GoogleService-Info.plist>
WOORISAI_FIREBASE_DEBUG_REALM_SHA256=<64-hex-debug-realm-digest>
WOORISAI_FIREBASE_RELEASE_REALM_SHA256=<64-hex-release-realm-digest>
