# Production archive and App Store Connect inputs.
# Copy this file to .env.production, keep that file mode 0600, and replace every placeholder.
WOORISAI_API_HOST=<production-api-hostname-without-scheme>
WOORISAI_FIREBASE_RELEASE_CONFIG_PATH=<absolute-path-to-release-GoogleService-Info.plist>
WOORISAI_FIREBASE_RELEASE_REALM_SHA256=<64-hex-release-realm-digest>
WOORISAI_FIREBASE_DEBUG_REALM_SHA256=<64-hex-debug-realm-digest>
APP_STORE_CONNECT_KEY_PATH=<absolute-path-to-App-Store-Connect-private-key.p8>
APP_STORE_CONNECT_KEY_ID=<10-character-key-id>
APP_STORE_CONNECT_ISSUER_ID=<issuer-uuid>
IOS_MARKETING_VERSION=<major.minor.patch>
IOS_BUILD_NUMBER=<positive-integer-build-number>
