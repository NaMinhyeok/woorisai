# Production backend runtime template. Copy to .env.production and keep it untracked.
# Railway remains the runtime source of truth; never commit populated values.

PORT=8080

SPRING_DATASOURCE_URL=CHANGE_ME
SPRING_DATASOURCE_USERNAME=CHANGE_ME
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

MEDIA_UPLOADS_ENABLED=false
R2_ENDPOINT_URL=
R2_REGION_NAME=auto
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
MEDIA_UPLOAD_URL_TTL_SECONDS=900
MEDIA_DOWNLOAD_URL_TTL_SECONDS=300

FIREBASE_NOTIFICATIONS_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
